{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "getsignova.com" }],
      "destination": "https://www.getsignova.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "ebenova.dev" }],
      "destination": "https://www.ebenova.dev/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    },
    {
      "source": "/v1/scope/(.*)",
      "destination": "/api/v1/scope/$1"
    },
    {
      "source": "/v1/auth/(.*)",
      "destination": "/api/v1/auth/$1"
    },
    {
      "source": "/v1/(.*)",
      "destination": "/api/v1/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/docs",
      "destination": "/index.html"
    },
    {
      "source": "/api",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.ebenova.dev" }],
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "api.ebenova.dev" }],
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/scope-guard-analyze.js": {
      "maxDuration": 60
    },
    "api/v1/documents/batch.js": {
      "maxDuration": 120
    },
    "api/v1/documents/templates.js": {
      "maxDuration": 10
    },
    "api/v1/contracts/link.js": {
      "maxDuration": 15
    },
    "api/v1/scope/analyze.js": {
      "maxDuration": 60
    },
    "api/v1/scope/change-order.js": {
      "maxDuration": 60
    },
    "api/v1/auth/magic-link.js": {
      "maxDuration": 30
    },
    "api/v1/auth/verify.js": {
      "maxDuration": 30
    },
    "api/v1/documents/generate.js": {
      "maxDuration": 120
    },
    "api/v1/extract/conversation.js": {
      "maxDuration": 120
    },
    "api/v1/invoices/generate.js": {
      "maxDuration": 60
    },
    "api/v1/keys/create.js": {
      "maxDuration": 30
    },
    "api/v1/keys/usage.js": {
      "maxDuration": 30
    },
    "api/v1/documents/types.js": {
      "maxDuration": 30
    },
    "api/v1/billing/checkout.js": {
      "maxDuration": 30
    },
    "api/v1/billing/webhook.js": {
      "maxDuration": 30
    },
    "api/v1/billing/portal.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/.well-known/mcp/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:png|jpg|jpeg|svg|gif|webp|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS, PATCH" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Requested-With" },
        { "key": "Access-Control-Expose-Headers", "value": "Content-Length, X-Request-Id" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    }
  ]
}
