{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "getsignova.com" }],
      "destination": "https://www.getsignova.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "ebenova.dev" }],
      "destination": "https://www.ebenova.dev/$1",
      "permanent": true
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.svg",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    },
    {
      "source": "/v1/(.*)",
      "destination": "/api/v1/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/api",
      "destination": "/index.html"
    },
    {
      "source": "/docs",
      "destination": "/index.html"
    },
    {
      "source": "/insights/dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/insights",
      "destination": "/index.html"
    },
    {
      "source": "/vigil",
      "destination": "/index.html"
    },
    {
      "source": "/scope-guard",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/v1/vigil/authorize.js": { "maxDuration": 30 },
    "api/v1/vigil/analyze.js": { "maxDuration": 60 },
    "api/v1/vigil/score.js": { "maxDuration": 30 },
    "api/v1/vigil/report.js": { "maxDuration": 120 },
    "api/warmup.js": { "maxDuration": 30 },
    "api/scope-guard-analyze.js": { "maxDuration": 60 },
    "api/v1/documents/batch.js": { "maxDuration": 120 },
    "api/v1/documents/templates.js": { "maxDuration": 10 },
    "api/v1/contracts/link.js": { "maxDuration": 15 },
    "api/v1/scope/analyze.js": { "maxDuration": 60 },
    "api/v1/scope/change-order.js": { "maxDuration": 60 },
    "api/v1/auth/magic-link.js": { "maxDuration": 30 },
    "api/v1/auth/verify.js": { "maxDuration": 30 },
    "api/v1/documents/generate.js": { "maxDuration": 120 },
    "api/v1/extract/conversation.js": { "maxDuration": 120 },
    "api/v1/invoices/generate.js": { "maxDuration": 60 },
    "api/v1/keys/create.js": { "maxDuration": 30 },
    "api/v1/keys/usage.js": { "maxDuration": 30 },
    "api/v1/documents/types.js": { "maxDuration": 30 },
    "api/v1/billing/checkout.js": { "maxDuration": 30 },
    "api/v1/billing/webhook.js": { "maxDuration": 30 },
    "api/v1/billing/portal.js": { "maxDuration": 30 },
    "api/v1/insights/matches/draft.js": { "maxDuration": 60 },
    "api/v1/insights/monitors/create.js": { "maxDuration": 30 },
    "api/v1/insights/subscribe.js": { "maxDuration": 30 },
    "api/v1/insights/monitors/router.js": { "maxDuration": 30 },
    "api/v1/insights/monitors/list.js": { "maxDuration": 30 },
    "api/v1/insights/monitors/delete.js": { "maxDuration": 30 },
    "api/v1/insights/matches/list.js": { "maxDuration": 30 },
    "api/v1/insights/matches/feedback.js": { "maxDuration": 30 },
    "api/insights/request-access.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/.well-known/mcp/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/(.*\\.(?:png|jpg|jpeg|svg|gif|webp|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS, PATCH" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Requested-With" },
        { "key": "Access-Control-Expose-Headers", "value": "Content-Length, X-Request-Id" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    }
  ]
}
