{
  "crons": [
    {
      "path": "/v1/insights/poll",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/ots-upgrade",
      "schedule": "17 */2 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "getsignova.com" }],
      "destination": "https://www.getsignova.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "ebenova.dev" }],
      "destination": "https://www.ebenova.dev/$1",
      "permanent": true
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.svg",
      "permanent": false
    },
    {
      "source": "/vigil",
      "has": [{ "type": "host", "value": "www.getsignova.com" }],
      "destination": "https://www.ebenova.dev/vigil",
      "permanent": true
    },
    {
      "source": "/insights/:path*",
      "has": [{ "type": "host", "value": "www.getsignova.com" }],
      "destination": "https://www.ebenova.dev/insights/:path*",
      "permanent": true
    },
    {
      "source": "/docs",
      "has": [{ "type": "host", "value": "www.getsignova.com" }],
      "destination": "https://www.ebenova.dev/docs",
      "permanent": true
    },
    {
      "source": "/dashboard",
      "has": [{ "type": "host", "value": "www.getsignova.com" }],
      "destination": "https://www.ebenova.dev/dashboard",
      "permanent": true
    },
    {
      "source": "/api-landing",
      "has": [{ "type": "host", "value": "www.getsignova.com" }],
      "destination": "https://www.ebenova.dev/api-landing",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    },
    {
      "source": "/v1/insights/monitors",
      "destination": "/api/v1/insights/monitors/router"
    },
    {
      "source": "/v1/insights/matches",
      "destination": "/api/v1/insights/matches/list"
    },
    {
      "source": "/v1/insights/poll",
      "destination": "/api/v1/insights/poll"
    },
    {
      "source": "/v1/monitors",
      "destination": "/api/v1/insights/monitors/router"
    },
    {
      "source": "/stripe-webhook",
      "destination": "/api/stripe-webhook"
    },
    {
      "source": "/v1/(.*)",
      "destination": "/api/v1/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/api",
      "destination": "/index.html"
    },
    {
      "source": "/docs",
      "destination": "/index.html"
    },
    {
      "source": "/insights/dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/insights",
      "destination": "/index.html"
    },
    {
      "source": "/vigil",
      "destination": "/index.html"
    },
    {
      "source": "/scope-guard",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/v1/bookings.js": { "maxDuration": 30 },
    "api/v1/vigil/authorize.js": { "maxDuration": 30 },
    "api/v1/vigil/analyze.js": { "maxDuration": 60 },
    "api/v1/vigil/score.js": { "maxDuration": 30 },
    "api/v1/vigil/report.js": { "maxDuration": 120 },
    "api/scope-guard-analyze.js": { "maxDuration": 60 },
    "api/v1/documents/batch.js": { "maxDuration": 120 },
    "api/v1/documents/templates.js": { "maxDuration": 10 },
    "api/v1/contracts/link.js": { "maxDuration": 15 },
    "api/v1/scope/analyze.js": { "maxDuration": 60 },
    "api/v1/scope/change-order.js": { "maxDuration": 60 },
    "api/v1/auth/magic-link.js": { "maxDuration": 30 },
    "api/v1/auth/quick-key.js": { "maxDuration": 30 },
    "api/v1/auth/verify.js": { "maxDuration": 30 },
    "api/v1/documents/generate.js": { "maxDuration": 120 },
    "api/v1/extract/conversation.js": { "maxDuration": 120 },
    "api/v1/invoices/generate.js": { "maxDuration": 60 },
    "api/v1/keys/create.js": { "maxDuration": 30 },
    "api/v1/keys/usage.js": { "maxDuration": 30 },
    "api/v1/documents/types.js": { "maxDuration": 30 },
    "api/stripe-webhook.js": { "maxDuration": 30 },
    "api/v1/billing/checkout.js": { "maxDuration": 30 },
    "api/v1/billing/webhook.js": { "maxDuration": 30 },
    "api/v1/keys/self-serve.js": { "maxDuration": 30 },
    "api/v1/billing/portal.js": { "maxDuration": 30 },
    "api/v1/insights/matches/draft.js": { "maxDuration": 60 },
    "api/v1/insights/monitors/create.js": { "maxDuration": 30 },
    "api/v1/insights/subscribe.js": { "maxDuration": 30 },
    "api/v1/insights/monitors/router.js": { "maxDuration": 30 },
    "api/v1/insights/monitors/list.js": { "maxDuration": 30 },
    "api/v1/insights/monitors/delete.js": { "maxDuration": 30 },
    "api/v1/insights/matches/list.js": { "maxDuration": 30 },
    "api/v1/insights/matches/feedback.js": { "maxDuration": 30 },
    "api/v1/insights/poll.js": { "maxDuration": 300 },
    "api/extract-terms.js": { "maxDuration": 60 },
    "api/generate-preview.js": { "maxDuration": 60 },
    "api/generate.js": { "maxDuration": 120 },
    "api/geo.js": { "maxDuration": 10 },
    "api/mcp.js": { "maxDuration": 120 },
    "api/v1/admin/revenue.js": { "maxDuration": 60 },
    "api/cron/ots-upgrade.js": { "maxDuration": 300 }
  },
  "headers": [
    {
      "source": "/.well-known/mcp/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|woff2|webp|avif|png|svg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:jpg|jpeg|gif|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS, PATCH" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Requested-With" },
        { "key": "Access-Control-Expose-Headers", "value": "Content-Length, X-Request-Id" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/health",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://www.googletagmanager.com https://www.clarity.ms https://scripts.clarity.ms https://*.vercel-insights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://stats.g.doubleclick.net https://*.clarity.ms https://ipapi.co https://*.vercel-insights.com; frame-src https://www.loom.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';" }
      ]
    }
  ]
}
