{
  "serverInfo": { "name": "ebenova-scope-guard", "version": "1.1.0" },
  "authentication": { "required": true, "schemes": ["apiKey"] },
  "tools": [
    {
      "name": "analyze_scope_violation",
      "description": "Analyze a client message for scope violations against original contract terms. Optional jurisdiction parameter injects statute-aware analysis (CAMA / ERA 1996 / BCEA / Employment Act 2007 / etc.).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "contract_text": { "type": "string", "minLength": 50 },
          "client_message": { "type": "string" },
          "communication_channel": { "type": "string", "enum": ["email", "whatsapp", "slack", "sms", "other"] },
          "jurisdiction": {
            "type": "string",
            "enum": [
              "nigeria", "kenya", "ghana", "south_africa",
              "uk",
              "usa_federal", "usa_california", "usa_new_york", "usa_texas", "usa_florida",
              "canada_federal", "canada_ontario", "canada_bc", "canada_quebec",
              "eu", "india", "uae", "singapore"
            ]
          }
        },
        "required": ["contract_text", "client_message"]
      }
    },
    {
      "name": "generate_change_order",
      "description": "Generate a formal change order document for out-of-scope work. Optional jurisdiction parameter ensures jurisdiction-appropriate signature blocks and governing-law clause.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "additional_work": { "type": "string" },
          "additional_cost": { "type": "number" },
          "freelancer_name": { "type": "string" },
          "client_name": { "type": "string" },
          "currency": { "type": "string" },
          "timeline_extension_days": { "type": "integer" },
          "jurisdiction": {
            "type": "string",
            "enum": [
              "nigeria", "kenya", "ghana", "south_africa",
              "uk",
              "usa_federal", "usa_california", "usa_new_york", "usa_texas", "usa_florida",
              "canada_federal", "canada_ontario", "canada_bc", "canada_quebec",
              "eu", "india", "uae", "singapore"
            ]
          }
        },
        "required": ["additional_work", "additional_cost"]
      }
    }
  ],
  "resources": [],
  "prompts": []
}
