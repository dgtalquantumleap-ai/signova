    "non_compete_v1":              { "declared_title": "Non-Compete Agreement" },
    "payment_terms_v1":            { "declared_title": "Payment Terms Agreement" },
    "business_partnership_v1":     { "declared_title": "Business Partnership Agreement" },
    "joint_venture_v1":            { "declared_title": "Joint Venture Agreement" },
    "loan_agreement_v1":           { "declared_title": "Loan Agreement" },
    "shareholder_agreement_v1":    { "declared_title": "Shareholder Agreement" },
    "mou_v1":                      { "declared_title": "Memorandum of Understanding" },
    "letter_of_intent_v1":         { "declared_title": "Letter of Intent" },
    "distribution_agreement_v1":   { "declared_title": "Distribution Agreement" },
    "supply_agreement_v1":         { "declared_title": "Supply Agreement" },
    "business_proposal_v1":        { "declared_title": "Business Proposal" },
