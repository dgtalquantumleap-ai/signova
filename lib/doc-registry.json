    "safe_agreement_v1":            { "declared_title": "SAFE Agreement" }
  },
  "docTypes": {
    "service-agreement": {
      "id": "service-agreement",
      "title": "Service Agreement",
      "body_template_id": "service_agreement_v1",
      "required_clauses": [
        { "id": "scope",          "anyOf": ["scope of services", "scope of work", "services", "engagement"] },
        { "id": "fees",           "anyOf": ["fees", "remuneration", "payment", "compensation"] },
        { "id": "term",           "anyOf": ["term", "duration", "effective date"] },
        { "id": "termination",    "anyOf": ["termination", "term and termination"] },
        { "id": "governing-law",  "anyOf": ["governing law", "jurisdiction and governing law"] },
        { "id": "signature",      "anyOf": ["signature", "signed", "in witness whereof", "executed"] }
      ],
      "max_tokens": 16000,
      "jurisdiction_variants": {
        "default": { "title": "Service Agreement", "body_template_id": "service_agreement_v1" },
        "nigeria": { "title": "Service Agreement", "body_template_id": "service_agreement_ng_v1" }
      },
      "worker_classification_modes": ["independent_contractor", "exempt_worker_s91"],
      "worker_classification_rules": [
        {
          "mode": "independent_contractor",
          "require_any_of": ["invoice", "fee for services", "independent contractor", "contractor agreement"],
          "forbid_any_of": ["salary", "annual leave", "probation period"]
        },
        {
          "mode": "exempt_worker_s91",
          "require_any_of": ["manager", "managerial", "director", "executive", "professional services"],
          "forbid_any_of": ["manual labour", "operational worker", "clerical worker"]
        }
      ],
      "worker_classification_prompts": {
        "independent_contractor": "CLASSIFICATION ROUTING \u2014 INDEPENDENT CONTRACTOR (Nigeria). This document is generated for an independent-contractor relationship. Apply ONLY the clauses relevant to this classification:\n- Nothing in this Agreement creates a relationship of employment.\n- The Contractor is responsible for its own taxes; do NOT deduct PAYE from the fee.\n- Do NOT include pension contributions (Pension Reform Act 2014 applies to employer/employee only).\n- Do NOT include NSITF (Employees\u2019 Compensation Act 2010), NHF (NHF Act 1992), or ITF contributions \u2014 these apply to employees, not contractors.\n- Do NOT cite s.91 Labour Act worker-exemption. s.91 defines who is a \u2018worker\u2019 under the Labour Act; citing it implies a Labour Act relationship, which is itself inconsistent with an independent-contractor engagement.\nDo not hedge. Do not include clauses from other classification sets.",
        "exempt_worker_s91": "CLASSIFICATION ROUTING \u2014 EXEMPT WORKER under s.91 Labour Act (Nigeria). This document is generated for a managerial, professional, or executive EMPLOYMENT relationship that falls outside the Labour Act\u2019s \u2018worker\u2019 category per s.91. The engagement is still an employment relationship for tax, pension, and social-security purposes \u2014 s.91 only carves out Labour Act worker protections, it does NOT disapply Nigerian tax or social-security statutes.\n\nLABOUR ACT SCOPE (what s.91 DOES exempt):\n- Cite s.91 Labour Act expressly: the employee falls outside the \u2018worker\u2019 definition (manual/clerical/operational) in s.91.\n- Labour Act s.11 minimum-notice periods, s.7 written particulars window, and other worker-specific protections do NOT attach at statutory floor level.\n- Notice, leave, and termination are governed by the parties\u2019 express contractual terms rather than by Labour Act minimums.\n\nTAX / PENSION / SOCIAL SECURITY (what s.91 does NOT exempt \u2014 these MUST be included):\n- INCLUDE PAYE deductions per the Personal Income Tax Act (PITA). s.91 is a Labour Act concept; it does not affect PITA liability.\n- INCLUDE pension contributions per the Pension Reform Act 2014: employer 10% and employee 8% of monthly emoluments. PRA 2014 coverage of managerial/professional employees is not removed by s.91 Labour Act \u2014 pension obligations track the employment relationship, not the Labour Act worker definition.\n- INCLUDE NSITF contributions per the Employees\u2019 Compensation Act 2010 (1% of monthly emoluments, employer-borne). ECA 2010 applies to all employees.\n- INCLUDE NHF contributions per the NHF Act 1992 (2.5% of monthly basic salary, employee-deducted). NHF Act s.4 scopes to basic salary, excluding allowances.\n- INCLUDE ITF contributions per the ITF Act (1% of annual payroll, employer-borne).\n\nDo NOT include independent-contractor language (e.g. \u2018the parties are not in an employment relationship\u2019) \u2014 the s.91 exemption is about Labour Act scope only, not about whether an employment relationship exists. Do not hedge. Do not include clauses from other classification sets."
      },
      "forbidden_combinations": [
        {
          "id": "s91_with_paye_stack",
          "description": "Scoped to INDEPENDENT_CONTRACTOR only. An independent-contractor engagement sits outside the Labour Act framing entirely; citing s.91 in that context is legally incoherent because s.91 is a definitional carve-out WITHIN the Labour Act (i.e. presupposes an employee-employer relationship). A contractor doc that also applies PAYE / pension / NSITF / NHF / ITF compounds the error by invoking the employee-side statutory stack on what is purportedly a contractor engagement. NOTE: for an EXEMPT_WORKER_S91 managerial employee, the same textual combination is CORRECT and must not fire here \u2014 s.91 exempts the role from Labour Act worker protections, but the engagement remains an employment relationship for PITA, PRA 2014, ECA 2010, NHF Act, and ITF Act purposes. That case is excluded via applies_when_worker_classification_in below.",
          "applies_when_worker_classification_in": ["independent_contractor"],
          "anchors": [
            { "id": "s91", "patterns": ["s\\.\\s*91\\b", "section\\s+91\\b", "\\bs\\.91\\b"] },
            { "id": "paye_or_employee_deductions", "patterns": ["\\bPAYE\\b", "pension\\s+reform\\s+act", "pension\\s+contribution", "\\bNSITF\\b", "\\bNHF\\b", "\\bITF\\b"] }
          ]
        }
      ],
      "forbidden_titles": ["Contract of Employment", "Employment Contract", "Employment Agreement"]
    },
