    "data_processing_agreement_v1":{ "declared_title": "Data Processing Agreement" },
    "founders_agreement_v1":        { "declared_title": "Founders Agreement" },
    "ip_assignment_agreement_v1":   { "declared_title": "IP Assignment Agreement" },
    "advisory_board_agreement_v1":  { "declared_title": "Advisory Board Agreement" },
