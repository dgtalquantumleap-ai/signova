# ═══════════════════════════════════════════════════════════════
# EBENOVA.DEV API PLATFORM — ENVIRONMENT VARIABLES TEMPLATE
# ═══════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it's already in .gitignore
#
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]
#
# Get your Vercel environment variables at:
# vercel.com → your project → Settings → Environment Variables

# ═══════════════════════════════════════════════════════════════
# CORE API INFRASTRUCTURE [REQUIRED]
# ═══════════════════════════════════════════════════════════════

# Anthropic API (Claude) — Document generation
# Get your key at: https://console.anthropic.com/settings/keys
# Required for: /v1/documents/generate, /v1/extract/conversation
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Upstash Redis — API key storage + usage tracking
# Create free database at: https://console.upstash.com/redis
# Required for: All authenticated endpoints (API keys, rate limiting, usage)
UPSTASH_REDIS_REST_URL=https://YOUR_DATABASE_NAME.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN_HERE

# Ebenova Admin Secret — Protects API key creation endpoint
# Generate with: openssl rand -hex 32
# Required for: /v1/keys/create (admin-only endpoint)
EBENOVA_ADMIN_SECRET=YOUR_GENERATED_SECRET_HERE_64_CHARACTERS

# ═══════════════════════════════════════════════════════════════
# PAYMENT PROCESSING [OPTIONAL — Required for production]
# ═══════════════════════════════════════════════════════════════

# Stripe — Card payments (Signova consumer + Ebenova API subscriptions)
# Get keys at: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs — Main API plans
# Create at: stripe.com → Products → Add product → Add price (recurring, monthly)
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxx   # $29/mo
STRIPE_PRICE_GROWTH=price_xxxxxxxxxxxxxxxxxxxx    # $79/mo
STRIPE_PRICE_SCALE=price_xxxxxxxxxxxxxxxxxxxx     # $199/mo

# Stripe Price IDs — Insights add-on plans (separate products)
STRIPE_PRICE_INSIGHTS_STARTER=price_xxxxxxxxxxxxxxxxxxxx   # $49/mo
STRIPE_PRICE_INSIGHTS_GROWTH=price_xxxxxxxxxxxxxxxxxxxx    # $99/mo
STRIPE_PRICE_INSIGHTS_SCALE=price_xxxxxxxxxxxxxxxxxxxx     # $249/mo

# Polar — Subscription payments (API platform)
# Get keys at: polar.sh → Settings → Developers
POLAR_ACCESS_TOKEN=polar_at_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
POLAR_PRODUCT_ID=YOUR_PRODUCT_ID_HERE

# OxaPay — Crypto/USDT payments
# Get merchant key at: oxapay.com → Merchant Dashboard
OXAPAY_MERCHANT_KEY=YOUR_OXAPAY_MERCHANT_KEY

# Paystack — Nigerian Naira card payments
# Get keys at: dashboard.paystack.com → Settings → API keys & webhooks
PAYSTACK_SECRET_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Flutterwave — African card payments (Ghana, Kenya, etc.)
# Get keys at: dashboard.flutterwave.com → Settings → API
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════
# EMAIL NOTIFICATIONS [OPTIONAL]
# ═══════════════════════════════════════════════════════════════

# Resend — Transactional emails (waitlist, receipts, notifications)
# Get free API key at: resend.com → API keys
# Free tier: 3,000 emails/day
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Configure custom sending domain
# resend.com → Domains → Add Domain → getsignova.com
RESEND_FROM_ADDRESS=noreply@getsignova.com

# ═══════════════════════════════════════════════════════════════
# ALTERNATIVE AI PROVIDERS [OPTIONAL]
# ═══════════════════════════════════════════════════════════════

# Groq — Fast, cheap inference for previews (optional alternative to Anthropic)
# Get free API key at: console.groq.com/keys
# Free tier: Very generous, good for development
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Poll Cron Secret — protects the /v1/insights/poll cron endpoint
# Generate with: openssl rand -hex 32
# Required for: Vercel cron → /v1/insights/poll
POLL_CRON_SECRET=YOUR_GENERATED_SECRET_HERE_64_CHARACTERS

# Founder bypass — comma-separated emails that skip the 5/month preview rate limit.
# Useful for internal testing, demos, and barrister/partner reviews.
# These accounts are never billed for previews.
FOUNDER_BYPASS_EMAILS=olumide@ebenova.net,olumide@ebenovasolutions.com

# ═══════════════════════════════════════════════════════════════
# VIGIL FRAUD DETECTION [OPTIONAL]
# ═══════════════════════════════════════════════════════════════

# Vigil API URL — External Vigil backend (if deployed separately on Railway)
# The 4 Vigil endpoints work without this — they use the built-in proximity engine.
# Set this only if you've deployed the standalone Vigil backend.
VIGIL_API_URL=https://your-vigil-backend.up.railway.app

# Vigil API Secret — Shared secret for authenticating with the external Vigil backend
# Only needed if VIGIL_API_URL is set
VIGIL_API_SECRET=YOUR_GENERATED_SECRET_HERE

# Insights poller — max age of Reddit posts to consider (hours)
# Defaults to 24 hours if not set
INSIGHTS_POST_MAX_AGE_HOURS=24

# ═══════════════════════════════════════════════════════════════
# DOMAIN CONFIGURATION [REQUIRED FOR PRODUCTION]
# ═══════════════════════════════════════════════════════════════

# After deploying to Vercel, configure these domains:
# 1. getsignova.com → Signova consumer app (✅ Already configured)
# 2. api.ebenova.dev → API platform (⚠️ Pending DNS setup)
# 3. ebenova.dev → API documentation (⚠️ Pending DNS setup)
#
# DNS Setup Instructions:
# 1. Go to your domain registrar (where you bought ebenova.dev)
# 2. Change nameservers to:
#      ns1.vercel-dns.com
#      ns2.vercel-dns.com
# 3. In Vercel dashboard: Projects → signova → Settings → Domains
# 4. Add: api.ebenova.dev
# 5. Add: ebenova.dev
# 6. Wait 24-48 hours for DNS propagation
# 7. SSL is auto-provisioned by Vercel

# ═══════════════════════════════════════════════════════════════
# TESTING
# ═══════════════════════════════════════════════════════════════

# Test the API after deployment:
# 
# 1. Create your first API key:
#    curl -X POST https://api.ebenova.dev/v1/keys/create \
#      -H "Authorization: Bearer YOUR_EBENOVA_ADMIN_SECRET" \
#      -H "Content-Type: application/json" \
#      -d '{"owner":"test@customer.com","tier":"starter"}'
#
# 2. Generate a document:
#    curl -X POST https://api.ebenova.dev/v1/documents/generate \
#      -H "Authorization: Bearer sk_live_xxx" \
#      -H "Content-Type: application/json" \
#      -d '{"document_type":"nda","fields":{"disclosingParty":"Test Inc.","receivingParty":"John Smith","purpose":"Partnership discussion","duration":"2 years","mutual":"Yes"},"jurisdiction":"Nigeria"}'
#
# 3. Check usage:
#    curl -X GET https://api.ebenova.dev/v1/keys/usage \
#      -H "Authorization: Bearer sk_live_xxx"

# ═══════════════════════════════════════════════════════════════
# SECURITY NOTES
# ═══════════════════════════════════════════════════════════════

# - NEVER commit .env to git
# - Rotate EBENOVA_ADMIN_SECRET if it leaks
# - Use sk_test_ keys for development, sk_live_ for production
# - Enable rate limiting in production (configured in lib/api-auth.js)
# - Monitor usage in Vercel dashboard → Analytics
